<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FR-Audio Tech & Smart Tools Hub</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0f172a;
            --panel-bg: #1e293b;
            --accent-blue: #38bdf8;
            --accent-green: #4ade80;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --border-color: #334155;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        header {
            background-color: var(--panel-bg);
            padding: 1.5rem 2rem;
            border-bottom: 2px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        header h1 {
            font-size: 1.5rem;
            color: var(--accent-blue);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        header p {
            color: var(--text-muted);
            font-size: 0.875rem;
        }

        .main-container {
            flex: 1;
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 1.5rem;
            padding: 1.5rem;
        }

        /* Sidebar Navigation */
        .sidebar {
            background-color: var(--panel-bg);
            border-radius: 12px;
            padding: 1rem;
            border: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .nav-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            padding: 0.75rem 1rem;
            text-align: left;
            border-radius: 8px;
            cursor: pointer;
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            transition: all 0.2s ease;
        }

        .nav-btn:hover {
            background-color: rgba(56, 189, 248, 0.1);
            color: var(--accent-blue);
        }

        .nav-btn.active {
            background-color: var(--accent-blue);
            color: var(--bg-dark);
            font-weight: 600;
        }

        /* Content Area */
        .content-area {
            background-color: var(--panel-bg);
            border-radius: 12px;
            padding: 2rem;
            border: 1px solid var(--border-color);
            overflow-y: auto;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        /* Forms and Typography */
        h2 {
            margin-bottom: 1.5rem;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 0.5rem;
            color: var(--text-main);
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        @media (max-width: 768px) {
            .main-container {
                grid-template-columns: 1fr;
            }
            .grid-2 {
                grid-template-columns: 1fr;
            }
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        input, select {
            width: 100%;
            padding: 0.75rem;
            background-color: var(--bg-dark);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            color: var(--text-main);
            font-size: 1rem;
            transition: border-color 0.2s;
        }

        input:focus, select:focus {
            outline: none;
            border-color: var(--accent-blue);
        }

        button.btn-calc {
            background-color: var(--accent-blue);
            color: var(--bg-dark);
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            width: 100%;
            font-size: 1rem;
            transition: opacity 0.2s;
        }

        button.btn-calc:hover {
            opacity: 0.9;
        }

        /* Results Box */
        .result-box {
            background-color: rgba(56, 189, 248, 0.05);
            border: 1px dashed var(--accent-blue);
            border-radius: 8px;
            padding: 1.5rem;
            margin-top: 1rem;
        }

        .result-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.75rem;
            font-size: 1.05rem;
        }

        .result-item:last-child {
            margin-bottom: 0;
            padding-top: 0.75rem;
            border-top: 1px solid var(--border-color);
        }

        .val-highlight {
            color: var(--accent-green);
            font-weight: bold;
        }

        /* Mock Display Dashboard */
        .mock-lcd {
            background-color: #042f1a;
            color: #4ade80;
            font-family: 'Courier New', Courier, monospace;
            padding: 1.5rem;
            border-radius: 8px;
            border: 4px solid #1e293b;
            box-shadow: inset 0 0 10px rgba(0,0,0,0.8);
            margin-bottom: 1.5rem;
        }

        .lcd-line {
            font-size: 1.5rem;
            letter-spacing: 2px;
            height: 2rem;
            text-transform: uppercase;
        }

        .status-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1rem;
        }

        .status-card {
            background-color: var(--bg-dark);
            border: 1px solid var(--border-color);
            padding: 1rem;
            border-radius: 8px;
            text-align: center;
        }

        .status-card i {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
            color: var(--accent-blue);
        }

        .status-card.active i {
            color: var(--accent-green);
        }
    </style>
</head>
<body>

    <header>
        <h1><i class="fa-solid from-font fa-microchip"></i> WORKBENCH & TECH SYSTEM</h1>
        <p>Aplikasi Lab / Prototype Web Client-Side</p>
    </header>

    <div class="main-container">
        <!-- Sidebar -->
        <div class="sidebar">
            <button class="nav-btn active" onclick="switchTab(event, 'audio-calc')">
                <i class="fa-solid fa-wave-square"></i> Audio Power Calc
            </button>
            <button class="nav-btn" onclick="switchTab(event, 'smart-farm')">
                <i class="fa-solid fa-seedling"></i> Automation Monitoring
            </button>
            <button class="nav-btn" onclick="switchTab(event, 'stock-comp')">
                <i class="fa-solid fa-chart-line"></i> Dividend Goal Planner
            </button>
        </div>

        <!-- Content Area -->
        <div class="content-area">
            
            <!-- TAB 1: AUDIO CALCULATOR -->
            <div id="audio-calc" class="tab-content active">
                <h2>Kalkulator Daya & Catu Daya Amplifikasi Audio</h2>
                <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Hitung estimasi output daya RMS amplifier berdasarkan tegangan trafo (volt AC) setelah melewati penyearah (DC Drop) dan beban impedansi speaker.</p>
                
                <div class="grid-2">
                    <div>
                        <div class="form-group">
                            <label for="vac">Tegangan Trafo (Volt AC secondary - CT):</label>
                            <input type="number" id="vac" value="45" placeholder="Contoh: 32, 45, 55">
                        </div>
                        <div class="form-group">
                            <label for="impedance">Impedansi Speaker (Ohm):</label>
                            <select id="impedance">
                                <option value="8">8 Ohm</option>
                                <option value="4" selected>4 Ohm</option>
                                <option value="2">2 Ohm</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="efficiency">Estimasi Efisiensi Driver (Topology):</label>
                            <select id="efficiency">
                                <option value="0.65">Kelas AB (Sekitar 65%)</option>
                                <option value="0.85" selected>Kelas D (Sekitar 85%)</option>
                                <option value="0.50">Kelas A (Sekitar 50%)</option>
                            </select>
                        </div>
                        <button class="btn-calc" onclick="calculateAudio()">Hitung Estimasi Power</button>
                    </div>

                    <div>
                        <div class="result-box">
                            <h3 style="margin-bottom: 1rem; font-size: 1.1rem; color: var(--accent-blue);">Hasil Estimasi Output Teknis:</h3>
                            <div class="result-item">
                                <span>Tegangan DC Peak (VDC):</span>
                                <span id="vdc-res" class="val-highlight">0 V</span>
                            </div>
                            <div class="result-item">
                                <span>Estimasi V Peak-to-Peak (Clean):</span>
                                <span id="vpp-res" class="val-highlight">0 V</span>
                            </div>
                            <div class="result-item" style="border-top: 1px dashed var(--border-color); padding-top:0.5rem;">
                                <span>Potensi Daya Teoritis (Max):</span>
                                <span id="pmax-res" style="color: #f43f5e; font-weight: bold;">0 W</span>
                            </div>
                            <div class="result-item">
                                <span><strong>Daya RMS Murni (Est. Efisiensi):</strong></span>
                                <span id="prms-res" style="color: #4ade80; font-weight: bold; font-size: 1.3rem;">0 W RMS</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TAB 2: AUTOMATION MONITORING MOCK -->
            <div id="smart-farm" class="tab-content">
                <h2>Sistem Kontrol & Monitoring Otomatis (Simulasi)</h2>
                <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Simulasi antarmuka data mikrokontroler untuk memantau sistem kabut otomatis atau parameter lingkungan secara real-time.</p>
                
                <div class="mock-lcd">
                    <div class="lcd-line" id="lcd-1">SYS MIST STARTED</div>
                    <div class="lcd-line" id="lcd-2">RH: 82% | T: 26C</div>
                </div>

                <div class="grid-2">
                    <div>
                        <h3 style="margin-bottom: 1rem; font-size: 1.1rem;">Kontrol Simulator (Ubah nilai untuk melihat respon):</h3>
                        <div class="form-group">
                            <label for="sim-rh">Kelembapan Udara (RH %):</label>
                            <input type="range" id="sim-rh" min="40" max="100" value="78" oninput="updateSimulation()">
                            <span id="rh-val">78%</span>
                        </div>
                        <div class="form-group">
                            <label for="sim-temp">Suhu Lingkungan (°C):</label>
                            <input type="range" id="sim-temp" min="15" max="40" value="27" oninput="updateSimulation()">
                            <span id="temp-val">27°C</span>
                        </div>
                    </div>

                    <div>
                        <h3 style="margin-bottom: 1rem; font-size: 1.1rem;">Status Aktuator / Relay:</h3>
                        <div class="status-grid">
                            <div class="status-card" id="card-mist">
                                <i class="fa-solid fa-cloud-meatball"></i>
                                <div style="font-weight:600; margin-top:0.5rem;">Nozzle Kabut</div>
                                <div id="status-mist-txt" style="font-size:0.85rem; color:var(--text-muted);">MATI</div>
                            </div>
                            <div class="status-card" id="card-fan">
                                <i class="fa-solid fa-fan"></i>
                                <div style="font-weight:600; margin-top:0.5rem;">Kipas Exhaust</div>
                                <div id="status-fan-txt" style="font-size:0.85rem; color:var(--text-muted);">MATI</div>
                            </div>
                        </div>
                        <p style="margin-top: 1rem; font-size:0.85rem; color:var(--text-muted);">*Logika Otomatis: Jika RH di bawah 80%, Nozzle Kabut akan menyala otomatis untuk menaikkan kelembapan.</p>
                    </div>
                </div>
            </div>

            <!-- TAB 3: DIVIDEND GOAL PLANNER -->
            <div id="stock-comp" class="tab-content">
                <h2>Kalkulator Proyeksi Target Dividen Saham</h2>
                <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Hitung berapa banyak lembar atau lot saham yang perlu dikumpulkan untuk mencapai target penghasilan pasif tertentu berdasarkan yield dividen emiten.</p>

                <div class="grid-2">
                    <div>
                        <div class="form-group">
                            <label for="target-income">Target Penghasilan Pasif (Per Tahun / Rupiah):</label>
                            <input type="number" id="target-income" value="12000000" placeholder="Contoh: 12000000 (12 Juta)">
                        </div>
                        <div class="form-group">
                            <label for="share-price">Estimasi Harga Per Lembar Saham (Rp):</label>
                            <input type="number" id="share-price" value="3000" placeholder="Contoh: 3000">
                        </div>
                        <div class="form-group">
                            <label for="dps">Dividen Per Lembar / DPS (Rupiah per Tahun):</label>
                            <input type="number" id="dps" value="150" placeholder="Contoh: 150">
                        </div>
                        <button class="btn-calc" onclick="calculateDividends()">Hitung Kebutuhan Modal</button>
                    </div>

                    <div>
                        <div class="result-box" style="border-color: var(--accent-green); background-color: rgba(74, 222, 128, 0.05);">
                            <h3 style="margin-bottom: 1rem; font-size: 1.1rem; color: var(--accent-green);">Analisis Kebutuhan Aset:</h3>
                            <div class="result-item">
                                <span>Dividend Yield Emiten:</span>
                                <span id="yield-res" class="val-highlight">0%</span>
                            </div>
                            <div class="result-item">
                                <span>Total Lembar Diperlukan:</span>
                                <span id="shares-res" class="val-highlight">0 Lembar</span>
                            </div>
                            <div class="result-item">
                                <span><strong>Total LOT Diperlukan:</strong></span>
                                <span id="lot-res" style="color: var(--accent-blue); font-weight: bold; font-size: 1.2rem;">0 Lot</span>
                            </div>
                            <div class="result-item" style="border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
                                <span><strong>Estimasi Total Modal:</strong></span>
                                <span id="capital-res" style="color: #4ade80; font-weight: bold; font-size: 1.2rem;">Rp 0</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        // Tab Navigation Logic
        function switchTab(evt, tabId) {
            const contents = document.querySelectorAll('.tab-content');
            contents.forEach(content => content.classList.remove('active'));

            const buttons = document.querySelectorAll('.nav-btn');
            buttons.forEach(btn => btn.classList.remove('active'));

            document.getElementById(tabId).classList.add('active');
            evt.currentTarget.classList.add('active');
            
            if(tabId === 'smart-farm') {
                updateSimulation();
            }
        }

        // Tab 1: Audio Power Calculation
        function calculateAudio() {
            const vac = parseFloat(document.getElementById('vac').value) || 0;
            const imp = parseFloat(document.getElementById('impedance').value) || 4;
            const eff = parseFloat(document.getElementById('efficiency').value) || 0.85;

            // VDC peak = VAC * sqrt(2)
            const vdc = vac * 1.414;
            // Anggap drop tegangan pada beban berat & sag sekitar 10%
            const vdcDropped = vdc * 0.9; 
            
            // Rumus daya max murni sebelum kliping (V_peak kuadrat / (2 * R))
            const pMax = (vdcDropped * vdcDropped) / (2 * imp);
            // Daya riil dengan faktor efisiensi rangkaian/topologi
            const pRMS = pMax * eff;

            document.getElementById('vdc-res').innerText = vdc.toFixed(1) + ' VDC';
            document.getElementById('vpp-res').innerText = (vdcDropped * 2).toFixed(1) + ' Vpp';
            document.getElementById('pmax-res').innerText = pMax.toFixed(0) + ' Watt';
            document.getElementById('prms-res').innerText = pRMS.toFixed(0) + ' W RMS';
        }

        // Tab 2: Automation Simulation
        function updateSimulation() {
            const rh = document.getElementById('sim-rh').value;
            const temp = document.getElementById('sim-temp').value;

            document.getElementById('rh-val').innerText = rh + '%';
            document.getElementById('temp-val').innerText = temp + '°C';

            // Update LCD Text Simulation
            const lcd1 = document.getElementById('lcd-1');
            const lcd2 = document.getElementById('lcd-2');
            
            lcd2.innerText = `RH: ${rh}% | TEMP: ${temp}C`;

            const cardMist = document.getElementById('card-mist');
            const txtMist = document.getElementById('status-mist-txt');
            const cardFan = document.getElementById('card-fan');
            const txtFan = document.getElementById('status-fan-txt');

            // Logika Otomatisasi Sederhana
            if(parseInt(rh) < 80) {
                lcd1.innerText = "MIST SYSTEM: ON ";
                cardMist.classList.add('active');
                cardMist.style.borderColor = '#4ade80';
                txtMist.innerText = "MENYALA (Misting)";
                txtMist.style.color = '#4ade80';
            } else {
                lcd1.innerText = "MIST SYSTEM: OFF";
                cardMist.classList.remove('active');
                cardMist.style.borderColor = '#334155';
                txtMist.innerText = "MATI (Standby)";
                txtMist.style.color = '#94a3b8';
            }

            if(parseInt(temp) > 30) {
                cardFan.classList.add('active');
                cardFan.style.borderColor = '#4ade80';
                txtFan.innerText = "MENYALA (Overheat)";
                txtFan.style.color = '#4ade80';
            } else {
                cardFan.classList.remove('active');
                cardFan.style.borderColor = '#334155';
                txtFan.innerText = "MATI";
                txtFan.style.color = '#94a3b8';
            }
        }

        // Tab 3: Dividend Goal Planner
        function calculateDividends() {
            const target = parseFloat(document.getElementById('target-income').value) || 0;
            const price = parseFloat(document.getElementById('share-price').value) || 0;
            const dps = parseFloat(document.getElementById('dps').value) || 0;

            if (dps <= 0 || price <= 0) return;

            const yieldPercentage = (dps / price) * 100;
            const sharesNeeded = Math.ceil(target / dps);
            const lotsNeeded = Math.ceil(sharesNeeded / 100);
            const totalCapital = lotsNeeded * 100 * price;

            document.getElementById('yield-res').innerText = yieldPercentage.toFixed(2) + '%';
            document.getElementById('shares-res').innerText = sharesNeeded.toLocaleString('id-ID') + ' Lembar';
            document.getElementById('lot-res').innerText = lotsNeeded.toLocaleString('id-ID') + ' Lot';
            document.getElementById('capital-res').innerText = 'Rp ' + totalCapital.toLocaleString('id-ID');
        }

        // Initial Run on Load
        calculateAudio();
    </script>
</body>
</html>
